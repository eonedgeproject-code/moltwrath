# ─── MoltWrath Configuration ─────────────────────────────────────────────
MOLTWRATH_DEBUG=false
MOLTWRATH_LOG_LEVEL=INFO
MOLTWRATH_SECRET_KEY=change-me-in-production

# API
MOLTWRATH_API_HOST=0.0.0.0
MOLTWRATH_API_PORT=8000

# LLM Providers
MOLTWRATH_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
MOLTWRATH_DB_URL=sqlite+aiosqlite:///moltwrath.db

# Agent Defaults
MOLTWRATH_DEFAULT_MODEL=gpt-4
MOLTWRATH_DEFAULT_TEMPERATURE=0.7
MOLTWRATH_DEFAULT_MAX_TOKENS=4096
MOLTWRATH_MAX_AGENT_ITERATIONS=10
